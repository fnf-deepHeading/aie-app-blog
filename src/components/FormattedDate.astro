---
interface Props {
  date: Date;
}
const { date } = Astro.props;
const iso = date.toISOString();
const formatted = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date).replace(/\.\s?$/, '').replace(/\.\s/g, '.');
---
<time class="mono" datetime={iso}>{formatted}</time>
