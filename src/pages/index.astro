---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import featuredConfig from '../featured.json';

const all = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 최상단 고정 글: /admin 이 관리하는 featured.json 의 slug 가 1순위,
// 없으면 frontmatter featured, 그것도 없으면 최신 글.
const pinned = featuredConfig.slug ? all.find((p) => p.id === featuredConfig.slug) : undefined;
const featured = pinned ?? all.find((p) => p.data.featured) ?? all[0];
// 최신 글을 맨 앞에 두고, 나머지는 시간 역순 그대로
const ordered = featured ? [featured, ...all.filter((p) => p.id !== featured.id)] : all;
const total = all.length;

// 카테고리 + 글 수 (많은 순)
const counts = new Map<string, number>();
for (const p of all) counts.set(p.data.category, (counts.get(p.data.category) ?? 0) + 1);
const categories = [...counts.entries()].sort((a, b) => b[1] - a[1]);

// 태그 + 글 수 (많은 순, 동수면 이름순) — 홈 태그 필터용
const tagCounts = new Map<string, number>();
for (const p of all) for (const t of p.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<Base>
  <!-- Hero: thesis statement -->
  <section class="hero wrap">
    <div class="hero-main">
      <p class="eyebrow">AIE · App Part — 기술 블로그</p>
      <h1 class="hero-title">
        사내 AI를<br />
        <em>제품</em>으로 만든다.
      </h1>
      <p class="hero-lead">
        <span>플랫폼·에이전트·추천 모델·업무 자동화 — App 파트가 만드는 사내 AI는 한 가지가 아닙니다.</span>
        <span>모델을 붙이는 것보다 어려운 건 그 다음 — 배포, 권한, 운영, 그리고 사람들이 진짜로 쓰게 만드는 일.</span>
        <span>그 과정을 기록합니다.</span>
      </p>
    </div>
    {tags.length > 0 && (
      <div class="hero-tags" aria-label="태그 필터">
        <p class="ht-h mono">태그로 찾기</p>
        <div class="ht-list">
          <button type="button" class="tagbtn mono" data-tag="all" aria-pressed="true">전체</button>
          {tags.map(([t, c]) => (
            <button type="button" class="tagbtn mono" data-tag={t} aria-pressed="false">#{t}<span class="tn">{c}</span></button>
          ))}
        </div>
      </div>
    )}
  </section>

  <section class="board wrap">
    <!-- 좌측 카테고리 -->
    <aside class="sidebar" aria-label="카테고리">
      <p class="side-h mono">카테고리</p>
      <ul class="cats">
        <li>
          <button type="button" class="cat" data-cat="all" aria-current="true">
            <span class="cat-name">전체</span>
            <span class="cat-count mono">{total}</span>
          </button>
        </li>
        {categories.map(([name, count]) => (
          <li>
            <button type="button" class="cat" data-cat={name} aria-current="false">
              <span class="cat-name">{name}</span>
              <span class="cat-count mono">{count}</span>
            </button>
          </li>
        ))}
      </ul>
    </aside>

    <!-- 메인: 툴바 + 글 -->
    <div class="main">
      <div class="toolbar">
        <span class="count mono" data-count>{total}편</span>
        <div class="views" role="group" aria-label="보기 방식">
          <button type="button" class="vbtn" data-view="grid" aria-label="그리드 보기" aria-pressed="true">
            <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true" fill="currentColor">
              <rect x="1" y="1" width="6" height="6" rx="1"></rect>
              <rect x="9" y="1" width="6" height="6" rx="1"></rect>
              <rect x="1" y="9" width="6" height="6" rx="1"></rect>
              <rect x="9" y="9" width="6" height="6" rx="1"></rect>
            </svg>
          </button>
          <button type="button" class="vbtn" data-view="list" aria-label="리스트 보기" aria-pressed="false">
            <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true" fill="currentColor">
              <rect x="1" y="2" width="14" height="2.4" rx="1"></rect>
              <rect x="1" y="6.8" width="14" height="2.4" rx="1"></rect>
              <rect x="1" y="11.6" width="14" height="2.4" rx="1"></rect>
            </svg>
          </button>
        </div>
      </div>

      <div class="posts is-grid" id="posts">
        {ordered.map((post, i) => (
          <PostCard post={post} index={total - 1 - i} featured={post.id === featured?.id} />
        ))}
      </div>
      <p class="empty" data-empty hidden>조건에 맞는 글이 없습니다.</p>
    </div>
  </section>
</Base>

<script>
  const posts = document.getElementById('posts')!;
  const cards = Array.from(posts.querySelectorAll<HTMLElement>('.card'));
  const countEl = document.querySelector<HTMLElement>('[data-count]')!;
  const emptyEl = document.querySelector<HTMLElement>('[data-empty]')!;
  const viewBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view]'));
  const catBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-cat]'));

  // ── 뷰 전환 (localStorage 기억) ──────────────────────
  function setView(v: string) {
    posts.classList.toggle('is-grid', v === 'grid');
    posts.classList.toggle('is-list', v === 'list');
    viewBtns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.view === v)));
    try { localStorage.setItem('aie-view', v); } catch {}
  }
  viewBtns.forEach((b) => b.addEventListener('click', () => setView(b.dataset.view!)));
  let saved = 'grid';
  try { saved = localStorage.getItem('aie-view') || 'grid'; } catch {}
  setView(saved);

  // ── 카테고리 + 태그 필터 (둘 다 적용: AND) ───────────
  const tagBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag]'));
  let curCat = 'all';
  let curTag = 'all';

  function apply() {
    let n = 0;
    cards.forEach((card) => {
      const cat = card.dataset.category ?? '';
      const cardTags = (card.dataset.tags ?? '').split(',').filter(Boolean);
      const show =
        (curCat === 'all' || cat === curCat) &&
        (curTag === 'all' || cardTags.includes(curTag));
      card.hidden = !show;
      if (show) n++;
    });
    catBtns.forEach((b) => b.setAttribute('aria-current', String(b.dataset.cat === curCat)));
    tagBtns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.tag === curTag)));
    countEl.textContent = `${n}편`;
    emptyEl.hidden = n > 0;
  }
  catBtns.forEach((b) => b.addEventListener('click', () => { curCat = b.dataset.cat!; apply(); }));
  tagBtns.forEach((b) =>
    b.addEventListener('click', () => {
      // 활성 태그를 다시 누르면 해제(= 전체)
      curTag = curTag === b.dataset.tag && b.dataset.tag !== 'all' ? 'all' : b.dataset.tag!;
      apply();
    })
  );
</script>

<style>
  .hero {
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    display: flex;
    align-items: flex-start;
    gap: clamp(2rem, 5vw, 4.5rem);
  }
  .hero-main { flex: 1 1 auto; min-width: 0; }

  /* 제목 우측 태그 필터 */
  .hero-tags { flex: 0 0 auto; width: clamp(12rem, 22vw, 17rem); padding-top: 0.4rem; }
  .ht-h { color: var(--ink-3); margin-bottom: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; }
  .ht-list { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .tagbtn {
    font-size: var(--fs-xs);
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.28rem 0.62rem;
    cursor: pointer;
    transition: border-color .15s var(--ease), color .15s var(--ease), background .15s var(--ease);
  }
  .tagbtn:hover { border-color: var(--clay); color: var(--clay-2); }
  .tagbtn[aria-pressed="true"] { background: var(--clay-wash); border-color: var(--clay); color: var(--clay-2); }
  .tagbtn .tn { color: var(--ink-3); margin-left: 0.32em; }
  .tagbtn[aria-pressed="true"] .tn { color: var(--clay-2); }
  @media (max-width: 820px) {
    .hero { flex-direction: column; gap: 1.8rem; }
    .hero-tags { width: 100%; }
  }

  .hero-title {
    font-size: clamp(2.3rem, 7vw, var(--fs-3xl));
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin-top: 1.4rem;
    max-width: 16ch;
  }
  .hero-title em { font-style: normal; color: var(--clay); }
  .hero-lead {
    margin-top: 1.6rem;
    max-width: 40rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-2);
  }
  /* 문장 단위로 줄바꿈 — 폭이 되면 문장당 한 줄, 좁으면 균형 있게 접힘 */
  .hero-lead span { display: block; text-wrap: balance; }
  .hero-lead span + span { margin-top: 0.5em; }

  /* ── Board: 사이드바 + 메인 ─────────────────────────── */
  .board {
    display: grid;
    grid-template-columns: 200px minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .sidebar { position: sticky; top: 5.5rem; min-width: 0; }
  .main { min-width: 0; } /* 그리드 아이템이 콘텐츠 폭만큼 늘어나 가로 오버플로 나는 것 방지 */
  .side-h {
    color: var(--ink-3);
    letter-spacing: 0.14em;
    padding-bottom: 0.9rem;
    margin-bottom: 0.4rem;
    border-bottom: 2px solid var(--ink);
  }
  .cats { display: flex; flex-direction: column; }
  .cat {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    background: none;
    border: none;
    border-bottom: 1px solid var(--line);
    padding: 0.7rem 0;
    cursor: pointer;
    color: var(--ink-2);
    font-family: var(--sans);
    font-size: var(--fs-sm);
    text-align: left;
    white-space: nowrap;
    transition: color .18s var(--ease);
  }
  .cat:hover { color: var(--ink); }
  .cat-count { color: var(--ink-3); font-size: var(--fs-xs); }
  .cat[aria-current='true'] { color: var(--clay-2); font-weight: 600; }
  .cat[aria-current='true'] .cat-count { color: var(--clay); }

  /* ── Toolbar ────────────────────────────────────────── */
  .toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .count { color: var(--ink-2); }
  .views { display: inline-flex; gap: 0.3rem; }
  .vbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--ink-3);
    cursor: pointer;
    transition: color .18s var(--ease), border-color .18s var(--ease), background .18s var(--ease);
  }
  .vbtn:hover { color: var(--ink-2); }
  .vbtn[aria-pressed='true'] {
    color: var(--paper);
    background: var(--ink);
    border-color: var(--ink);
  }

  /* ── Posts container ────────────────────────────────── */
  .posts.is-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1080px) {
    .posts.is-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .posts.is-list { display: block; }
  .empty { padding: 3rem 0; color: var(--ink-3); }

  /* ── 반응형 ─────────────────────────────────────────── */
  @media (max-width: 860px) {
    .board { grid-template-columns: 1fr; gap: 1.5rem; }
    .sidebar { position: static; }
    .side-h { display: none; }
    .cats {
      flex-direction: row;
      gap: 0.5rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .cats::-webkit-scrollbar { display: none; }
    .cat {
      flex: 0 0 auto;
      border: 1px solid var(--line-2);
      border-radius: 999px;
      padding: 0.55rem 1rem;
      gap: 0.45rem;
    }
    .cat[aria-current='true'] { border-color: var(--clay); background: var(--clay-wash); }
    .vbtn { width: 2.5rem; height: 2.5rem; }
  }
  @media (max-width: 560px) {
    .posts.is-grid { grid-template-columns: 1fr; }
  }
</style>
