---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { readingTime, withBase, splitTitle } from '../../utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
  );
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { title, description, category, pubDate, updatedDate, author, tags } = post.data;
const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasToc = toc.length > 2;
const mins = readingTime(post.body);
const t = splitTitle(title);
---
<Base title={title} description={description}>
  <article class:list={{ 'has-toc': hasToc }}>
    <header class="post-head wrap">
      <span class="eyebrow">{category}</span>
      <h1 class="post-title">{t.main}{t.sub && <span class="post-subtitle">{t.sub}</span>}</h1>
      <p class="post-desc">{description}</p>
      <div class="post-meta">
        <span class="mono author">{author}</span>
        <span class="sep" aria-hidden="true"></span>
        <FormattedDate date={pubDate} />
        <span class="dot" aria-hidden="true">·</span>
        <span class="mono">{mins}분 읽기</span>
        {updatedDate && (
          <span class="updated mono">· 수정 {updatedDate.toISOString().slice(0, 10)}</span>
        )}
      </div>
    </header>

    <div class="post-body wrap">
      {hasToc && (
        <details class="toc" open>
          <summary class="toc-label mono">목차</summary>
          <nav aria-label="목차">
            <ol>
              {toc.map((h) => (
                <li class={`toc-d${h.depth}`}>
                  <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      )}

      <div class="post-content">
        <div class="prose">
          <Content />
        </div>

        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((t) => <span class="tag mono">#{t}</span>)}
          </div>
        )}
      </div>
    </div>

    <nav class="post-nav wrap" aria-label="다른 글">
      {prev ? (
        <a href={withBase(`/posts/${prev.id}/`)} class="nav-card prev">
          <span class="mono dir">← 이전</span>
          <span class="nav-t">{prev.data.title}</span>
        </a>
      ) : <span />}
      {next ? (
        <a href={withBase(`/posts/${next.id}/`)} class="nav-card next">
          <span class="mono dir">다음 →</span>
          <span class="nav-t">{next.data.title}</span>
        </a>
      ) : <span />}
    </nav>
  </article>
</Base>

<style>
  /* 글 상세는 넓은 컨테이너 안에서 읽기 좋은 폭으로 가운데 정렬 */
  .post-head, .post-body, .post-nav { max-width: var(--measure-post); }
  .post-head {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }
  .post-title {
    font-size: clamp(1.9rem, 5vw, var(--fs-2xl));
    font-weight: 700;
    line-height: 1.12;
    margin-top: 1.1rem;
    max-width: 26ch;
    text-wrap: balance;
  }
  /* 제목의 " — " 뒤 부제는 다음 줄에 작게·연하게 */
  .post-subtitle {
    display: block;
    margin-top: 0.3em;
    font-size: 0.5em;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink-2);
    text-wrap: balance;
  }
  .post-subtitle::before { content: '— '; color: var(--clay); }
  .post-desc {
    margin-top: 1.2rem;
    font-size: var(--fs-md);
    color: var(--ink-2);
    max-width: var(--measure-text);
    line-height: 1.55;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.6rem;
    flex-wrap: wrap;
  }
  .author { color: var(--clay-2); font-weight: 500; }
  .sep { width: 1.5rem; height: 1px; background: var(--line-2); }
  .dot { color: var(--ink-3); }
  .updated { color: var(--ink-3); }

  .post-body { padding-top: 2.5rem; }

  /* 앵커 점프 시 헤딩이 화면 맨 위에 딱 붙지 않게 */
  .prose :global(h2), .prose :global(h3) { scroll-margin-top: 1.5rem; }

  /* --- 목차 (TOC) ------------------------------------------- */
  .toc {
    margin-bottom: 2.5rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-2);
    max-width: var(--measure-text);
  }
  .toc-label {
    cursor: pointer;
    color: var(--ink-2);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5em;
  }
  .toc-label::-webkit-details-marker { display: none; }
  .toc-label::before {
    content: '';
    width: 1.4em; height: 1px;
    background: var(--clay);
  }
  .toc nav { margin-top: 0.9rem; }
  .toc ol { display: flex; flex-direction: column; gap: 0.1rem; }
  .toc li { max-width: none; }
  .toc a {
    display: block;
    padding: 0.28rem 0;
    font-size: var(--fs-sm);
    line-height: 1.4;
    color: var(--ink-2);
    border-left: 2px solid transparent;
    padding-left: 0.8rem;
    margin-left: -0.8rem;
    transition: color .15s var(--ease), border-color .15s var(--ease);
  }
  .toc a:hover { color: var(--clay-2); }
  .toc-d3 a { padding-left: 1.9rem; font-size: var(--fs-xs); color: var(--ink-3); }
  .toc a.is-active { color: var(--clay-2); border-left-color: var(--clay); }

  /* 와이드 화면: 목차를 읽기 컬럼 왼쪽 레일로 — 본문/헤더/네비 정렬을 함께 맞춘다 */
  @media (min-width: 1180px) {
    .has-toc .post-head,
    .has-toc .post-nav {
      max-width: calc(var(--measure-post) + 16rem);
      padding-left: calc(var(--gut) + 16rem);
    }
    .has-toc .post-body {
      max-width: calc(var(--measure-post) + 16rem);
      display: grid;
      grid-template-columns: 13rem minmax(0, 1fr);
      column-gap: 3rem;
      align-items: start;
    }
    .has-toc .toc {
      position: sticky;
      top: 2rem;
      margin-bottom: 0;
      padding: 0;
      border: none;
      background: none;
      max-width: none;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
    }
    .has-toc .toc[open] .toc-label,
    .has-toc .toc .toc-label { pointer-events: none; }
    .has-toc .toc-label::-webkit-details-marker { display: none; }
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    max-width: var(--measure-text);
  }
  .post-tags .tag {
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3.5rem;
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-2);
    transition: border-color .2s var(--ease);
  }
  .nav-card:hover { border-color: var(--clay); }
  .nav-card.next { text-align: right; align-items: flex-end; }
  .dir { color: var(--ink-3); }
  .nav-t {
    font-family: var(--sans);
    font-weight: 600;
    font-size: var(--fs-md);
    line-height: 1.25;
    color: var(--ink);
  }
  .nav-card:hover .nav-t { color: var(--clay-2); }
  @media (max-width: 600px) {
    .post-nav { grid-template-columns: 1fr; }
    .nav-card.next { text-align: left; align-items: flex-start; }
  }

  /* 본문 이미지: 클릭하면 확대 */
  .prose :global(img) { cursor: zoom-in; }

  /* mermaid 다이어그램 */
  :global(.mermaid-fig) { margin: 1.8em 0; text-align: center; overflow-x: auto; }
  :global(.mermaid-fig svg) { max-width: 100%; height: auto; }

  /* 이미지 확대 라이트박스 (body에 동적 삽입 → :global) */
  :global(.lightbox) {
    position: fixed; inset: 0; z-index: 200;
    display: none; align-items: center; justify-content: center;
    padding: 4vmin; cursor: zoom-out;
    background: color-mix(in srgb, var(--ink) 84%, transparent);
    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
  }
  :global(.lightbox.open) { display: flex; }
  :global(.lightbox img) {
    max-width: 100%; max-height: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--line-2);
    box-shadow: 0 24px 60px rgba(28, 27, 23, 0.45);
  }
  :global(.lightbox .lb-close) {
    position: absolute; top: 1.1rem; right: 1.3rem;
    font-family: var(--mono); font-size: var(--fs-xs); letter-spacing: 0.08em;
    color: var(--paper); background: none; cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--paper) 45%, transparent);
    border-radius: var(--radius); padding: 0.4rem 0.7rem;
  }
</style>

<script>
  // 스크롤에 따라 현재 섹션을 목차에서 하이라이트
  const links = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>('.toc a[data-slug]').forEach((a) => {
    const slug = a.dataset.slug;
    if (slug) links.set(slug, a);
  });

  if (links.size) {
    const headings = document.querySelectorAll<HTMLElement>('.prose h2, .prose h3');
    let active: string | null = null;

    const setActive = (slug: string | null) => {
      if (slug === active) return;
      if (active) links.get(active)?.classList.remove('is-active');
      if (slug) links.get(slug)?.classList.add('is-active');
      active = slug;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // 화면 상단 가까이에 보이는 헤딩들 중 가장 위의 것을 활성화
        const visible = entries
          .filter((e) => e.isIntersecting)
          .map((e) => e.target as HTMLElement);
        if (visible.length) {
          const top = visible.reduce((a, b) =>
            a.getBoundingClientRect().top < b.getBoundingClientRect().top ? a : b
          );
          if (top.id) setActive(top.id);
        }
      },
      { rootMargin: '0px 0px -75% 0px', threshold: 0 }
    );

    headings.forEach((h) => h.id && observer.observe(h));
  }
</script>

<script>
  // 본문 이미지 클릭 → 라이트박스 확대 (Esc·배경 클릭으로 닫기)
  const imgs = document.querySelectorAll<HTMLImageElement>('.prose img');
  if (imgs.length) {
    let overlay: HTMLElement | null = null;
    const close = () => {
      overlay?.classList.remove('open');
      document.body.style.overflow = '';
    };
    const open = (src: string, alt: string) => {
      if (!overlay) {
        overlay = document.createElement('div');
        overlay.className = 'lightbox';
        overlay.innerHTML =
          '<button class="lb-close" type="button" aria-label="닫기">ESC ✕</button><img alt="">';
        overlay.addEventListener('click', close);
        document.body.appendChild(overlay);
      }
      const big = overlay.querySelector('img') as HTMLImageElement;
      big.src = src;
      big.alt = alt;
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    };
    imgs.forEach((img) => {
      img.addEventListener('click', () => open(img.currentSrc || img.src, img.alt));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }

  // mermaid 코드블록 → 실제 다이어그램 (있을 때만 mermaid 동적 로드)
  const mmd = document.querySelectorAll<HTMLElement>('pre[data-language="mermaid"]');
  if (mmd.length) {
    const { default: mermaid } = await import('mermaid');
    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      securityLevel: 'loose',
      fontFamily: 'inherit',
      themeVariables: {
        background: '#FFFFFF',
        primaryColor: '#FAFAFA',
        primaryBorderColor: '#B090F0',
        primaryTextColor: '#211E29',
        lineColor: '#B090F0',
        secondaryColor: '#FFFFFF',
        tertiaryColor: '#FAFAFA',
        clusterBkg: '#FFFFFF',
        clusterBorder: '#C9B8F0',
        edgeLabelBackground: '#FFFFFF',
        titleColor: '#211E29',
      },
    });
    let i = 0;
    for (const pre of mmd) {
      const code = (pre.textContent || '').trim();
      if (!code) continue;
      try {
        const { svg } = await mermaid.render('mmd-' + i++, code);
        const fig = document.createElement('figure');
        fig.className = 'mermaid-fig';
        fig.innerHTML = svg;
        pre.replaceWith(fig);
      } catch {
        /* 렌더 실패 시 원본 코드블록 유지 */
      }
    }
  }
</script>
