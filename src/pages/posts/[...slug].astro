---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { readingTime } from '../../utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
  );
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { title, description, category, pubDate, updatedDate, author, tags } = post.data;
const { Content } = await render(post);
const mins = readingTime(post.body);
---
<Base title={title} description={description}>
  <article>
    <header class="post-head wrap">
      <span class="eyebrow">{category}</span>
      <h1 class="post-title">{title}</h1>
      <p class="post-desc">{description}</p>
      <div class="post-meta">
        <span class="mono author">{author}</span>
        <span class="sep" aria-hidden="true"></span>
        <FormattedDate date={pubDate} />
        <span class="dot" aria-hidden="true">·</span>
        <span class="mono">{mins}분 읽기</span>
        {updatedDate && (
          <span class="updated mono">· 수정 {updatedDate.toISOString().slice(0, 10)}</span>
        )}
      </div>
    </header>

    <div class="post-body wrap">
      <div class="prose">
        <Content />
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <span class="tag mono">#{t}</span>)}
        </div>
      )}
    </div>

    <nav class="post-nav wrap" aria-label="다른 글">
      {prev ? (
        <a href={`/posts/${prev.id}/`} class="nav-card prev">
          <span class="mono dir">← 이전</span>
          <span class="nav-t">{prev.data.title}</span>
        </a>
      ) : <span />}
      {next ? (
        <a href={`/posts/${next.id}/`} class="nav-card next">
          <span class="mono dir">다음 →</span>
          <span class="nav-t">{next.data.title}</span>
        </a>
      ) : <span />}
    </nav>
  </article>
</Base>

<style>
  /* 글 상세는 넓은 컨테이너 안에서 읽기 좋은 폭으로 가운데 정렬 */
  .post-head, .post-body, .post-nav { max-width: var(--measure-post); }
  .post-head {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }
  .post-title {
    font-size: clamp(2.25rem, 6vw, var(--fs-2xl));
    line-height: 1.08;
    margin-top: 1.1rem;
    max-width: 20ch;
  }
  .post-desc {
    margin-top: 1.2rem;
    font-size: var(--fs-md);
    color: var(--ink-2);
    max-width: var(--measure-text);
    line-height: 1.55;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.6rem;
    flex-wrap: wrap;
  }
  .author { color: var(--clay-2); font-weight: 500; }
  .sep { width: 1.5rem; height: 1px; background: var(--line-2); }
  .dot { color: var(--ink-3); }
  .updated { color: var(--ink-3); }

  .post-body { padding-top: 2.5rem; }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    max-width: var(--measure-text);
  }
  .post-tags .tag {
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3.5rem;
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-2);
    transition: border-color .2s var(--ease);
  }
  .nav-card:hover { border-color: var(--clay); }
  .nav-card.next { text-align: right; align-items: flex-end; }
  .dir { color: var(--ink-3); }
  .nav-t {
    font-family: var(--serif);
    font-size: var(--fs-md);
    line-height: 1.25;
    color: var(--ink);
  }
  .nav-card:hover .nav-t { color: var(--clay-2); }
  @media (max-width: 600px) {
    .post-nav { grid-template-columns: 1fr; }
    .nav-card.next { text-align: left; align-items: flex-start; }
  }
</style>
