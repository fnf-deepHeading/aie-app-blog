---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import featuredConfig from '../featured.json';

// 빌드 시점에 글 목록을 심는다(최신순). 현재 고정 slug 도 함께.
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    date: p.data.pubDate.toISOString().slice(0, 10),
    category: p.data.category,
  }));

// GitHub 커밋 대상 — featured.json 한 파일만 건드린다(1커밋·1빌드).
const REPO = { owner: 'fnf-deepHeading', name: 'aie-app-blog', branch: 'main', path: 'src/featured.json' };
const currentSlug = featuredConfig.slug ?? '';
---
<Base title="관리자" noindex>
  <section class="admin wrap">
    <p class="eyebrow">ADMIN</p>
    <h1>최상단 노출 글 관리</h1>
    <p class="lead">
      홈 최상단(featured)에 고정할 글을 고른다. 저장하면 GitHub의
      <code>src/featured.json</code> 한 파일만 커밋되고, 약 1분 뒤 자동 배포로 반영된다.
      <strong>정적 사이트라 이 선택은 재빌드를 거쳐 모든 방문자에게 적용된다.</strong>
    </p>

    <!-- 1) 토큰 -->
    <div class="panel">
      <h2 class="mono">1 · GitHub 토큰</h2>
      <p class="hint">
        이 레포 <strong>Contents: Read &amp; Write</strong> 권한의 fine-grained PAT.
        토큰은 이 브라우저(localStorage)에만 보관되고 GitHub API 외 어디로도 전송되지 않는다.
        공용 PC에서는 작업 후 <em>토큰 지우기</em>를 누를 것.
      </p>
      <div class="row">
        <input id="token" type="password" placeholder="github_pat_..." autocomplete="off" spellcheck="false" />
        <button id="clear-token" type="button" class="ghost mono">토큰 지우기</button>
      </div>
      <p class="hint">
        발급: GitHub → Settings → Developer settings → Fine-grained tokens →
        Repository access는 <code>aie-app-blog</code>만, Permissions에서 <code>Contents: Read and write</code>.
      </p>
    </div>

    <!-- 2) 글 선택 -->
    <div class="panel">
      <h2 class="mono">2 · 최상단 글 선택</h2>
      <p class="hint">현재 고정: <code id="current">{currentSlug || '(없음 — 최신 글 자동)'}</code> <span class="hint-dim">(마지막 빌드 기준)</span></p>
      <ul id="post-list" class="posts"></ul>
    </div>

    <!-- 3) 저장 -->
    <div class="panel">
      <button id="save" type="button" class="primary">저장 (커밋 → 자동 배포)</button>
      <p id="status" class="status" role="status" aria-live="polite"></p>
    </div>
  </section>

  <script define:vars={{ posts, currentSlug, REPO }}>
    const $ = (id) => document.getElementById(id);
    const TOKEN_KEY = 'aie-admin-token';
    const API = 'https://api.github.com';

    // --- 토큰 ---
    const tokenInput = $('token');
    tokenInput.value = localStorage.getItem(TOKEN_KEY) || '';
    tokenInput.addEventListener('input', () => localStorage.setItem(TOKEN_KEY, tokenInput.value.trim()));
    $('clear-token').addEventListener('click', () => {
      localStorage.removeItem(TOKEN_KEY);
      tokenInput.value = '';
      setStatus('토큰을 지웠다.', 'ok');
    });

    // --- 글 목록(라디오) ---
    const list = $('post-list');
    list.innerHTML = '';
    for (const p of posts) {
      const li = document.createElement('li');
      const checked = p.id === currentSlug ? 'checked' : '';
      li.innerHTML =
        '<label><input type="radio" name="featured" value="' + p.id + '" ' + checked + '>' +
        '<span class="p-main"><span class="p-title">' + escapeHtml(p.title) + '</span>' +
        '<span class="p-meta mono">' + escapeHtml(p.category) + ' · ' + p.date + ' · ' + escapeHtml(p.id) + '</span></span></label>';
      list.appendChild(li);
    }

    // --- 저장 ---
    $('save').addEventListener('click', save);

    async function save() {
      const token = (localStorage.getItem(TOKEN_KEY) || '').trim();
      if (!token) return setStatus('먼저 GitHub 토큰을 입력하라.', 'err');
      const sel = document.querySelector('input[name="featured"]:checked');
      if (!sel) return setStatus('고정할 글을 선택하라.', 'err');
      const slug = sel.value;
      if (slug === currentSlug) return setStatus('이미 그 글이 최상단이다(빌드 기준). 그래도 다시 커밋하려면 다른 글을 골랐다 되돌려라.', 'err');

      const btn = $('save');
      btn.disabled = true;
      setStatus('GitHub에 커밋 중…', 'busy');
      try {
        const url = API + '/repos/' + REPO.owner + '/' + REPO.name + '/contents/' + REPO.path;
        // 최신 sha 조회(빌드 시점 이후 변경 대비)
        const getRes = await fetch(url + '?ref=' + REPO.branch, {
          headers: { Authorization: 'Bearer ' + token, Accept: 'application/vnd.github+json' },
        });
        if (!getRes.ok) throw new Error('파일 조회 실패 (HTTP ' + getRes.status + ') — 토큰 권한/레포 확인');
        const cur = await getRes.json();

        const body = JSON.stringify({ slug }, null, 2) + '\n';
        const content = b64utf8(body);
        const putRes = await fetch(url, {
          method: 'PUT',
          headers: { Authorization: 'Bearer ' + token, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: 'admin: 최상단 글을 ' + slug + ' (으)로 변경',
            content,
            sha: cur.sha,
            branch: REPO.branch,
          }),
        });
        if (!putRes.ok) {
          const t = await putRes.text();
          throw new Error('커밋 실패 (HTTP ' + putRes.status + ') ' + t.slice(0, 200));
        }
        setStatus('✅ 커밋됨 — 약 1분 뒤 사이트에 반영된다. (Actions에서 진행 확인 가능)', 'ok');
        $('current').textContent = slug;
      } catch (e) {
        setStatus('⚠️ ' + (e && e.message ? e.message : String(e)), 'err');
      } finally {
        btn.disabled = false;
      }
    }

    function setStatus(msg, kind) {
      const el = $('status');
      el.dataset.kind = kind || '';
      if (kind === 'busy') {
        const fli = import.meta.env.BASE_URL + 'fli.png';
        el.innerHTML =
          '<span class="fli-loader" style="flex-direction:row;gap:0.6rem;">' +
          '<img src="' + fli + '" alt="" style="width:30px;height:30px;" />' +
          escapeHtml(msg) + '</span>';
      } else {
        el.textContent = msg;
      }
    }
    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }
    // UTF-8 안전 base64
    function b64utf8(str) {
      return btoa(String.fromCharCode(...new TextEncoder().encode(str)));
    }
  </script>

  <style>
    .admin { max-width: var(--measure-post); padding-block: clamp(2.5rem, 6vw, 4.5rem); }
    .admin h1 { font-size: clamp(2rem, 5vw, var(--fs-2xl)); margin-top: 0.6rem; }
    .lead { margin-top: 1rem; color: var(--ink-2); font-size: var(--fs-md); line-height: 1.55; max-width: var(--measure-text); }
    .lead code { font-size: 0.85em; }

    .panel {
      margin-top: 2rem;
      padding: 1.4rem 1.5rem;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--paper-2);
    }
    .panel h2 { font-family: var(--mono); font-size: var(--fs-xs); letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-2); }
    .hint { margin-top: 0.7rem; font-size: var(--fs-sm); color: var(--ink-2); line-height: 1.6; }
    .hint-dim { color: var(--ink-3); }
    .hint code, .lead code, #current { font-family: var(--mono); font-size: 0.86em; background: var(--paper); border: 1px solid var(--line); padding: 0.08em 0.4em; border-radius: 3px; }

    .row { display: flex; gap: 0.7rem; margin-top: 0.9rem; flex-wrap: wrap; }
    #token {
      flex: 1; min-width: 16rem;
      font-family: var(--mono); font-size: var(--fs-sm);
      padding: 0.6rem 0.8rem;
      border: 1px solid var(--line-2); border-radius: var(--radius); background: var(--paper);
    }
    #token:focus-visible { outline: 2px solid var(--clay); }

    .posts { margin-top: 0.9rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .posts li { list-style: none; }
    .posts label {
      display: flex; gap: 0.8rem; align-items: flex-start;
      padding: 0.7rem 0.9rem; border: 1px solid var(--line); border-radius: var(--radius);
      background: var(--paper); cursor: pointer; transition: border-color .15s var(--ease);
    }
    .posts label:hover { border-color: var(--clay); }
    .posts input { margin-top: 0.35em; accent-color: var(--clay); }
    .p-main { display: flex; flex-direction: column; gap: 0.2rem; }
    .p-title { font-family: var(--sans); font-weight: 600; font-size: var(--fs-md); line-height: 1.2; }
    .p-meta { font-size: var(--fs-xs); color: var(--ink-3); }

    button { font-family: var(--mono); font-size: var(--fs-xs); letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; border-radius: var(--radius); }
    .primary { padding: 0.8rem 1.4rem; background: var(--clay); color: var(--paper); border: 1px solid var(--clay); }
    .primary:hover { background: var(--clay-2); border-color: var(--clay-2); }
    .primary:disabled { opacity: 0.5; cursor: default; }
    .ghost { padding: 0.6rem 0.9rem; background: transparent; color: var(--ink-2); border: 1px solid var(--line-2); }
    .ghost:hover { border-color: var(--clay); color: var(--clay-2); }

    .status { margin-top: 1rem; font-size: var(--fs-sm); line-height: 1.5; min-height: 1.2em; }
    .status[data-kind="ok"] { color: #2f7d4f; }
    .status[data-kind="err"] { color: var(--clay-2); }
    .status[data-kind="busy"] { color: var(--ink-2); }
  </style>
</Base>
