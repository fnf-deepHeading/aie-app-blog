---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
import { withBase } from '../utils';

const principles = [
  {
    k: '데모가 아니라 운영',
    v: '되는 걸 보여주는 건 시작일 뿐이다. 사업부가 매일 쓰는 플랫폼으로 만드는 과정 — 배포·권한·안정화·비용까지 적는다.',
  },
  {
    k: '결정을 남긴다',
    v: '코드보다 오래 가는 건 “왜 그렇게 했나”다. 선택지와 트레이드오프, 기각한 안까지 적는다.',
  },
  {
    k: '헛디딘 것도 쓴다',
    v: '잘된 사례만 모으면 광고가 된다. 되돌린 결정, 틀린 가정, 새벽에 잡은 장애도 똑같이 기록한다.',
  },
];

// 팀원(닉네임) + 한 줄. ※ 초안 — 각자 한 줄은 본인이 다듬을 것.
const team = [
  { name: '쿠키', line: '흩어진 업무 맥락을 묶는 주간보고 파이프라인·멀티에이전트 오케스트레이션.' },
  { name: '조이', line: '로그로 스스로 절차를 고치는 운영 에이전트(zoee.alter, FAPO).' },
  { name: '키티', line: '업무 일지·운영 업무를 자동화하는 개인 에이전트(kitty.alter).' },
  { name: '호이', line: 'AI 도구 설정을 한눈에 보는 관측 도구·AI Native 작업 환경(hoy.alter).' },
  { name: '차차', line: '(소개 준비 중)' },
];
---
<Base title="소개" description="AIE·App 파트가 이 블로그를 쓰는 이유.">
  <section class="about wrap">
    <p class="eyebrow">소개</p>
    <h1 class="about-title">
      앱을 만드는<br />사람들의 기록.
    </h1>
    <p class="about-lead">
      {SITE.title} 파트는 F&amp;F 사업부가 쓰는 사내 AI 플랫폼(DCS AI)과 에이전트,
      데이터 분석계를 만듭니다. 여기에는 그걸 만들며 부딪힌 문제와 풀어낸 과정을
      적습니다. 발표용으로 다듬은 사례집이 아니라, 다음 사람이 같은 곳에서 덜
      헤매도록 남기는 작업 노트에 가깝습니다.
    </p>

    <ul class="principles">
      {principles.map((p, i) => (
        <li class="principle">
          <span class="p-idx mono">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h2 class="p-k">{p.k}</h2>
            <p class="p-v">{p.v}</p>
          </div>
        </li>
      ))}
    </ul>

    <section class="team" aria-label="팀원">
      <h2 class="team-h">팀</h2>
      <p class="team-sub">{SITE.title} 파트 — 5명이 14개 활성 프로젝트에 걸쳐 일합니다.</p>
      <ul class="members">
        {team.map((m) => (
          <li class="member">
            <span class="m-name">{m.name}</span>
            <span class="m-line">{m.line}</span>
          </li>
        ))}
      </ul>
    </section>

    <div class="about-foot">
      <p class="mono">함께 만들고 싶다면 — App Part, F&amp;F</p>
      <a href={withBase('/')} class="back mono">← 글 보러 가기</a>
    </div>
  </section>
</Base>

<style>
  .about { max-width: var(--measure-post); padding-top: clamp(2.5rem, 6vw, 4.5rem); padding-bottom: 2rem; }
  .about-title {
    font-size: clamp(2.5rem, 7vw, var(--fs-2xl));
    line-height: 1.06;
    margin-top: 1.3rem;
  }
  .about-lead {
    margin-top: 1.6rem;
    max-width: var(--measure-text);
    font-size: var(--fs-md);
    line-height: 1.62;
    color: var(--ink-2);
  }
  .principles {
    margin-top: 3.5rem;
    border-top: 2px solid var(--ink);
  }
  .principle {
    display: flex;
    gap: 1.5rem;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--line);
  }
  .p-idx { color: var(--clay); padding-top: 0.35rem; font-weight: 500; }
  .p-k { font-size: var(--fs-lg); line-height: 1.2; }
  .p-v { margin-top: 0.5rem; color: var(--ink-2); max-width: 40rem; line-height: 1.6; }
  .team { margin-top: 3.5rem; }
  .team-h { font-size: var(--fs-lg); }
  .team-sub { margin-top: 0.4rem; color: var(--ink-3); font-size: var(--fs-sm); }
  .members {
    margin-top: 1.5rem;
    border-top: 2px solid var(--ink);
  }
  .member {
    display: flex;
    gap: 1.2rem;
    align-items: baseline;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
  }
  .m-name {
    flex: 0 0 4.5rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .m-line { color: var(--ink-2); font-size: var(--fs-sm); line-height: 1.55; max-width: 40rem; }
  @media (max-width: 560px) {
    .member { flex-direction: column; gap: 0.25rem; }
    .m-name { flex: none; }
  }

  .about-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .about-foot .mono { color: var(--ink-3); }
  .back { color: var(--clay-2) !important; }
</style>
